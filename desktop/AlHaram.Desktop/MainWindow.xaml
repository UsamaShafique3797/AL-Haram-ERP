<Window x:Class="AlHaram.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Al-Haram Steel"
        Icon="Assets/app.ico"
        Height="900"
        Width="1400"
        MinHeight="700"
        MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">
  <Grid>
    <Grid x:Name="LoadingPanel" Background="#F4F6F8">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
        <Image Source="Assets/logo.png" Width="96" Height="96" HorizontalAlignment="Center" Margin="0,0,0,16" />
        <TextBlock Text="Al-Haram Steel" FontSize="28" FontWeight="SemiBold" Foreground="#1F2933" HorizontalAlignment="Center" />
        <TextBlock Text="Starting local server and database…" FontSize="14" Foreground="#52606D" HorizontalAlignment="Center" Margin="0,12,0,20" />
        <ProgressBar IsIndeterminate="True" Height="6" />
        <TextBlock x:Name="StatusText" Text="Please wait" FontSize="12" Foreground="#7B8794" HorizontalAlignment="Center" Margin="0,16,0,0" TextWrapping="Wrap" TextAlignment="Center" />
      </StackPanel>
    </Grid>

    <Grid x:Name="ErrorPanel" Visibility="Collapsed" Background="#F4F6F8">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="520">
        <TextBlock Text="Could not start Al-Haram Steel" FontSize="22" FontWeight="SemiBold" Foreground="#C0392B" HorizontalAlignment="Center" />
        <TextBlock x:Name="ErrorText" FontSize="13" Foreground="#52606D" Margin="0,16,0,24" TextWrapping="Wrap" TextAlignment="Center" />
        <Button Content="Retry" Width="120" Height="36" HorizontalAlignment="Center" Click="Retry_Click" />
      </StackPanel>
    </Grid>

    <wv2:WebView2 x:Name="WebView" Visibility="Collapsed" />
  </Grid>
</Window>
